# Multi-Agent RAG Test Case Generation System - Environment Configuration
# Copy this file to .env and fill in your actual credentials

# --- GCP Configuration (Required) ---
# Google Cloud Project ID for BigQuery and Storage
GOOGLE_PROJECT_ID="your-project-id"
GCS_BUCKET="your-bucket-name"
BIGQUERY_DATASET="your-dataset-name"
GCP_REGION="us-central1"

# --- Vector DB (ChromaDB Cloud - Optional) ---
# If not provided, system uses local ChromaDB
CHROMA_API_KEY="your-chroma-api-key"
CHROMA_TENANT="your-tenant-id"
CHROMA_DATABASE="your-database-name"

# --- ALM Tools (Jira - Required for test case creation) ---
JIRA_API_URL="https://your-domain.atlassian.net"
JIRA_USER="your-email@domain.com"
JIRA_TOKEN="your-jira-api-token"
JIRA_PROJECT_KEY="YOUR-PROJECT-KEY"

# --- AI/ML Services (Optional) ---
# Local Hugging Face model for text generation
HUGGING_FACE_GENERATION_MODEL="google/flan-t5-small"

# --- Custom Services (Optional) ---
# OCR service for document processing
OCR_FUNCTION_URL="https://your-ocr-service.com/extract"

# Feedback and training services
FEEDBACK_API_URL="http://localhost:8002/feedback"
TRAINING_API_URL="http://localhost:8001/retrain"
FEEDBACK_GCS_URI="gs://your-feedback-bucket/feedback.jsonl"

# --- System Configuration (Optional) ---
# Override default settings if needed
# CHUNK_SIZE=256
# EMBEDDING_DIMENSIONS=384
# QUALITY_THRESHOLD=0.7